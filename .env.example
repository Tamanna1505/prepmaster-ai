# PrepMaster AI — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env` / `.env.local`.

# PostgreSQL connection string used by Prisma (Migrate) and the runtime driver adapter.
# Works with Neon, Supabase, local Postgres, etc.
# Example: postgresql://USER:PASSWORD@HOST:5432/prepmaster?schema=public
DATABASE_URL=""

# Secret used by Auth.js / NextAuth to sign the session JWT.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Canonical app URL.
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI provider key for real AI feedback. If empty, the app falls back
# to rule-based feedback.
AI_API_KEY=""
