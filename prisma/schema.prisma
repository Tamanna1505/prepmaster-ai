// PrepMaster AI — Prisma schema (Phase 10)
// Prisma 7: the connection URL lives in prisma.config.ts (not here), and the
// runtime PrismaClient is constructed with a driver adapter (see lib/db.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  ADMIN
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LessonType {
  TEXT
  VIDEO
}

enum QuestionType {
  SINGLE_CORRECT
  NUMERIC
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TestType {
  FULL_MOCK
  SECTIONAL
  TOPIC_QUIZ
  PREVIOUS_YEAR
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole  @default(STUDENT)
  targetExam   String?
  bio          String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollments       Enrollment[]
  lessonProgress    LessonProgress[]
  testAttempts      TestAttempt[]
  blogPosts         BlogPost[]         @relation("BlogAuthor")
  aiRecommendations AIRecommendation[]

  @@index([role])
}

model Course {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String
  description String
  coverImage  String?
  examTag     String?
  level       CourseLevel   @default(BEGINNER)
  price       Int           @default(0) // in paise/cents; 0 = free
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  modules     Module[]
  enrollments Enrollment[]

  @@index([status, examTag])
}

model Module {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  summary    String?
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lessons Lesson[]

  @@unique([courseId, orderIndex])
  @@index([courseId])
}

model Lesson {
  id              String     @id @default(cuid())
  moduleId        String
  module          Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  type            LessonType @default(VIDEO)
  body            String
  videoUrl        String?
  durationMinutes Int?
  isFreePreview   Boolean    @default(false)
  orderIndex      Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  progress LessonProgress[]

  @@unique([moduleId, orderIndex])
  @@index([moduleId])
}

model Enrollment {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Question {
  id                   String       @id @default(cuid())
  type                 QuestionType @default(SINGLE_CORRECT)
  stem                 String
  passage              String?
  // For SINGLE_CORRECT: Array<{ id: string; text: string; isCorrect: boolean }>.
  // For NUMERIC: null (use correctNumeric + tolerance).
  options              Json?
  correctNumeric       Float?
  tolerance            Float?
  explanation          String
  section              String
  topic                String
  subTopic             String?
  difficulty           Difficulty   @default(MEDIUM)
  defaultPositiveMarks Float        @default(1)
  defaultNegativeMarks Float        @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  testQuestions TestQuestion[]
  testAnswers   TestAnswer[]

  @@index([topic, difficulty, type])
  @@index([section])
}

model Test {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  description     String
  examTag         String?
  testType        TestType      @default(FULL_MOCK)
  durationMinutes Int
  positiveMarks   Float         @default(1)
  negativeMarks   Float         @default(0)
  difficulty      Difficulty    @default(MEDIUM)
  status          PublishStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  testQuestions TestQuestion[]
  attempts      TestAttempt[]

  @@index([status, examTag])
}

model TestQuestion {
  id                    String   @id @default(cuid())
  testId                String
  test                  Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionId            String
  question              Question @relation(fields: [questionId], references: [id], onDelete: Restrict)
  sectionName           String?
  orderIndex            Int
  positiveMarksOverride Float?
  negativeMarksOverride Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([testId, questionId])
  @@unique([testId, orderIndex])
  @@index([questionId])
}

model TestAttempt {
  id                    String        @id @default(cuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId                String
  test                  Test          @relation(fields: [testId], references: [id], onDelete: Restrict)
  status                AttemptStatus @default(IN_PROGRESS)
  startedAt             DateTime      @default(now())
  submittedAt           DateTime?
  durationSeconds       Int           @default(0)
  totalScore            Float?
  maxScore              Float?
  accuracyPct           Float?
  percentile            Float?
  // Last auto-saved client state (answers + remaining time) for resume.
  answersSnapshot       Json?
  aiFeedback            String?
  aiFeedbackGeneratedAt DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  answers          TestAnswer[]
  aiRecommendation AIRecommendation?

  @@index([userId, submittedAt])
  @@index([testId])
  @@index([status])
}

model TestAnswer {
  id                String      @id @default(cuid())
  attemptId         String
  attempt           TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOptionIds Json        @default("[]") // string[] of option ids
  numericAnswer     Float?
  isMarkedForReview Boolean     @default(false)
  isCorrect         Boolean? // computed at submission
  marksAwarded      Float? // computed at submission
  timeSpentSeconds  Int?
  answeredAt        DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model BlogPost {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  category       String
  excerpt        String
  body           String
  coverImage     String?
  seoTitle       String?
  seoDescription String?
  tags           Json          @default("[]")
  authorId       String
  author         User          @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  status         PublishStatus @default(DRAFT)
  publishedAt    DateTime?
  isFeatured     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([isFeatured])
}

model AIRecommendation {
  id               String       @id @default(cuid())
  // Optionally tied to a user and/or a specific attempt.
  userId           String?
  user             User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  attemptId        String?      @unique
  attempt          TestAttempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  summary          String
  strengths        Json         @default("[]")
  weaknesses       Json         @default("[]")
  recommendedSteps Json         @default("[]")
  source           String       @default("rule-based") // "rule-based" | "ai"
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([userId])
}
